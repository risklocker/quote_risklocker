APP_ENV=production
APP_NAME=Risklocker Quotation Converter
DATABASE_PROVIDER=supabase_postgres
DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
CORS_ORIGINS=https://YOUR_FRONTEND_HOST
AUTH_HASH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
AUTH_CODE_EXPIRE_MINUTES=10
AUTH_CODE_MAX_ATTEMPTS=5
AUTH_CODE_RESEND_SECONDS=60
SESSION_IDLE_HOURS=8
SESSION_MAX_DAYS=30
SESSION_COOKIE_NAME=risklocker_session
SESSION_COOKIE_SECURE=true
SMTP_HOST=YOUR_SMTP_RELAY_HOST
SMTP_PORT=587
SMTP_USERNAME=YOUR_SMTP_USERNAME
SMTP_PASSWORD=YOUR_BACKEND_ONLY_SMTP_PASSWORD
SMTP_FROM_EMAIL=no-reply@risklocker.com
SMTP_STARTTLS=true
SMTP_USE_SSL=false
INITIAL_ADMIN_EMAIL=first.last@risklocker.com
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_BACKEND_ONLY_SERVICE_ROLE_KEY
STORAGE_DRIVER=supabase
SUPABASE_STORAGE_BUCKET=risklocker-pdfs
PDF_RETENTION_DAYS=30
MAX_UPLOAD_BYTES=1048576
REQUIRE_MALWARE_SCANNER=true
TRASH_RETENTION_DAYS=14
