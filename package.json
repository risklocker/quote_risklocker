{
  "name": "risklocker-quotation-converter",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "backend": "powershell -NoProfile -ExecutionPolicy Bypass -File commands/start-backend.ps1",
    "frontend": "powershell -NoProfile -ExecutionPolicy Bypass -File commands/start-frontend.ps1",
    "full": "powershell -NoProfile -ExecutionPolicy Bypass -File commands/start-full.ps1",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File commands/stop-app.ps1",
    "test": "powershell -NoProfile -ExecutionPolicy Bypass -File commands/test-all.ps1",
    "code-map": ".venv\\Scripts\\python.exe commands/update-code-map.py --write",
    "code-map:check": ".venv\\Scripts\\python.exe commands/update-code-map.py --check"
  }
}
